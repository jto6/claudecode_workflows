#!/usr/bin/env bash
# bulletize — fast path via direct API when ANTHROPIC_API_KEY or ANTHROPIC_BASE_URL is set,
# otherwise falls back to `claude -p /bulletize ...`.
# -summarize always routes to slow path (preserves /distill chaining).
set -euo pipefail

REPO="$(dirname "$(dirname "$(readlink -f "$0")")")"
CLIP="${CLIP_BIN:-$REPO/bin/clip}"

FORCE_SLOW=0
FORCE_FAST=0
STDIN_MODE=0
MMAP=0
SUMMARIZE=0
TONE="default"
OUTFILE=""
BACKEND=""
TEXT_INLINE=""
HAS_POSITIONAL=0
PASSTHROUGH=()

while [ $# -gt 0 ]; do
	case "$1" in
		-h|--help)
			cat <<'EOF'
Usage: bulletize [OPTIONS] [FILE|URL|AUDIO]

Convert text to hierarchical bullet points.
Default: reads from clipboard, writes back to clipboard.

Input:
  (default)          read from clipboard
  --stdin            read from stdin
  --text TEXT        process TEXT directly (output to stdout)
  FILE|URL|AUDIO     input source (slow path only)

Options:
  -h, --help         show this help
  --fast             force fast path (direct API)
  --slow             force slow path (claude -p)
  --backend BACKEND  fast-path backend: anthropic (default) or local (Ollama)
  -conversational    conversational tone for text-clean pre-processing
  -journal           journal tone for text-clean pre-processing
  -basic             spelling/grammar/punctuation only (no style changes)
  -mmap              omit leading "- " prefix (for mind-map tools)
  -summarize         summarize before bulletizing (always slow path)
  -outfile FILE      write output to FILE instead of clipboard

Fast path requires ANTHROPIC_API_KEY or ANTHROPIC_BASE_URL.
Local backend requires Ollama at OLLAMA_HOST (default: http://localhost:11434).
EOF
			exit 0 ;;
		--slow) FORCE_SLOW=1; shift ;;
		--fast) FORCE_FAST=1; shift ;;
		--stdin) STDIN_MODE=1; shift ;;
		--backend) BACKEND="$2"; shift 2 ;;
		--text) TEXT_INLINE="$2"; shift 2 ;;
		-conversational) TONE="conversational"; PASSTHROUGH+=("$1"); shift ;;
		-journal)        TONE="journal";        PASSTHROUGH+=("$1"); shift ;;
		-basic)          TONE="basic";          PASSTHROUGH+=("$1"); shift ;;
		-mmap)           MMAP=1;                PASSTHROUGH+=("$1"); shift ;;
		-summarize)      SUMMARIZE=1;           PASSTHROUGH+=("$1"); shift ;;
		-outfile)        OUTFILE="$2";          PASSTHROUGH+=("$1" "$2"); shift 2 ;;
		-*)
			echo "bulletize: unknown option: $1" >&2
			echo "Run 'bulletize --help' for usage." >&2
			exit 1 ;;
		*)          HAS_POSITIONAL=1; PASSTHROUGH+=("$1"); shift ;;
	esac
done

# Decide path
USE_FAST=0
if [ "$SUMMARIZE" -eq 1 ]; then
	USE_FAST=0  # always slow — preserves /distill chaining
elif [ "$BACKEND" = "local" ]; then
	USE_FAST=1
elif [ "$FORCE_FAST" -eq 1 ]; then
	if [ -z "${ANTHROPIC_API_KEY:-}" ] && [ -z "${ANTHROPIC_BASE_URL:-}" ]; then
		echo "bulletize: --fast requires ANTHROPIC_API_KEY or ANTHROPIC_BASE_URL" >&2
		exit 1
	fi
	USE_FAST=1
elif [ "$FORCE_SLOW" -eq 1 ]; then
	USE_FAST=0
elif { [ -n "${ANTHROPIC_API_KEY:-}" ] || [ -n "${ANTHROPIC_BASE_URL:-}" ]; } \
     && [ "$HAS_POSITIONAL" -eq 0 ]; then
	USE_FAST=1
fi

if [ "$USE_FAST" -eq 1 ]; then
	case "$TONE" in
		conversational) CLEAN_PROMPT="$REPO/prompts/text-clean.conversational.md" ;;
		journal)        CLEAN_PROMPT="$REPO/prompts/text-clean.journal.md" ;;
		basic)          CLEAN_PROMPT="$REPO/prompts/text-clean.basic.md" ;;
		*)              CLEAN_PROMPT="$REPO/prompts/text-clean.md" ;;
	esac
	BULLETIZE_PROMPT="$REPO/prompts/bulletize.md"
	SUFFIX=""
	if [ "$MMAP" -eq 1 ]; then
		SUFFIX='Omit the leading "- " prefix from each line; output only tab indentation followed by text.'
	fi
	BACKEND_ARGS=()
	[ -n "$BACKEND" ] && BACKEND_ARGS=(--backend "$BACKEND")
	# Local models ignore system-prompt-only instructions more readily; reinforce
	# the transform goal (and mmap constraint) in the user message via --local-reminder.
	if [ "$MMAP" -eq 1 ]; then
		_BULLETIZE_REMINDER='REMINDER: Output ONLY the bullet-formatted version of the text. CRITICAL: Do NOT use "- " on any line — use ONLY tab characters for indentation followed by plain text. No preamble, no fences, no explanation.'
	else
		_BULLETIZE_REMINDER='REMINDER: Output ONLY the bullet-formatted version of the text, using tabs for indentation and "- " prefix on every line as shown in the system prompt examples. No preamble, no fences, no explanation.'
	fi
	BULLETIZE_EXTRA_ARGS=(--local-reminder "$_BULLETIZE_REMINDER")
	if [ -n "$TEXT_INLINE" ]; then
		RESULT=$(printf '%s' "$TEXT_INLINE" \
			| "$REPO/bin/llm-rewrite" "${BACKEND_ARGS[@]}" "$CLEAN_PROMPT" \
			| "$REPO/bin/llm-rewrite" "${BACKEND_ARGS[@]}" "${BULLETIZE_EXTRA_ARGS[@]}" "$BULLETIZE_PROMPT" "$SUFFIX")
		if [ -n "$OUTFILE" ]; then
			printf '%s' "$RESULT" > "$OUTFILE"
			echo "Bulletized: $OUTFILE"
		else
			printf '%s\n' "$RESULT"
		fi
	elif [ "$STDIN_MODE" -eq 1 ]; then
		"$REPO/bin/llm-rewrite" "${BACKEND_ARGS[@]}" "$CLEAN_PROMPT" \
			| "$REPO/bin/llm-rewrite" "${BACKEND_ARGS[@]}" "${BULLETIZE_EXTRA_ARGS[@]}" "$BULLETIZE_PROMPT" "$SUFFIX"
	else
		RESULT=$("$CLIP" read \
			| "$REPO/bin/llm-rewrite" "${BACKEND_ARGS[@]}" "$CLEAN_PROMPT" \
			| "$REPO/bin/llm-rewrite" "${BACKEND_ARGS[@]}" "${BULLETIZE_EXTRA_ARGS[@]}" "$BULLETIZE_PROMPT" "$SUFFIX")
		if [ -n "$OUTFILE" ]; then
			printf '%s' "$RESULT" > "$OUTFILE"
			echo "Bulletized: $OUTFILE"
		else
			printf '%s' "$RESULT" | "$CLIP" write
			echo "Bulletized: clipboard"
		fi
	fi
else
	if [ -n "$TEXT_INLINE" ] || [ "$STDIN_MODE" -eq 1 ]; then
		# claude -p cannot read from stdin as input text; route through temp files
		# so the slash command gets a file path and writes output we can capture.
		_TMP_IN=$(mktemp /tmp/bulletize-in.XXXXXX.txt)
		_TMP_OUT=$(mktemp /tmp/bulletize-out.XXXXXX.txt)
		if [ -n "$TEXT_INLINE" ]; then
			printf '%s' "$TEXT_INLINE" > "$_TMP_IN"
		else
			cat > "$_TMP_IN"
		fi
		# Wrap claude in `script` to allocate a PTY: when authenticated via claude.ai
		# OAuth (no ANTHROPIC_API_KEY), `claude -p` requires a TTY to load credentials,
		# otherwise it exits immediately with apiKeySource:"none" and empty result.
		# -E never disables PTY echo (keeps the typescript clean and prevents claude
		# from hanging on echoed stdin). Outer `</dev/null` closes the parent stdin.
		# --permission-mode bypassPermissions: /bulletize uses the Write tool to produce
		# $_TMP_OUT, which would otherwise prompt for approval and fail in headless mode.
		script -q -E never -c \
			"claude -p --permission-mode bypassPermissions '/bulletize${PASSTHROUGH[*]:+ ${PASSTHROUGH[*]}} -outfile $_TMP_OUT $_TMP_IN'" \
			/dev/null </dev/null >&2
		_STATUS=$?
		cat "$_TMP_OUT"
		rm -f "$_TMP_IN" "$_TMP_OUT"
		exit $_STATUS
	fi
	exec claude -p "/bulletize${PASSTHROUGH[*]:+ ${PASSTHROUGH[*]}}"
fi
