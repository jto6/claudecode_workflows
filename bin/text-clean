#!/usr/bin/env bash
# text-clean — fast path via direct API when ANTHROPIC_API_KEY or ANTHROPIC_BASE_URL is set,
# otherwise falls back to `claude -p /text-clean ...`.
set -euo pipefail

REPO="$(dirname "$(dirname "$(readlink -f "$0")")")"
CLIP="${CLIP_BIN:-$REPO/bin/clip}"

FORCE_SLOW=0
FORCE_FAST=0
STDIN_MODE=0
TONE="default"
OUTFILE=""
HAS_POSITIONAL=0
PASSTHROUGH=()

while [ $# -gt 0 ]; do
	case "$1" in
		--slow) FORCE_SLOW=1; shift ;;
		--fast) FORCE_FAST=1; shift ;;
		--stdin) STDIN_MODE=1; shift ;;
		-conversational) TONE="conversational"; PASSTHROUGH+=("$1"); shift ;;
		-journal)        TONE="journal";        PASSTHROUGH+=("$1"); shift ;;
		-outfile)        OUTFILE="$2";          PASSTHROUGH+=("$1" "$2"); shift 2 ;;
		-*)              PASSTHROUGH+=("$1");   shift ;;
		*)               HAS_POSITIONAL=1;      PASSTHROUGH+=("$1"); shift ;;
	esac
done

# Decide path
USE_FAST=0
if [ "$FORCE_FAST" -eq 1 ]; then
	if [ -z "${ANTHROPIC_API_KEY:-}" ] && [ -z "${ANTHROPIC_BASE_URL:-}" ]; then
		echo "text-clean: --fast requires ANTHROPIC_API_KEY or ANTHROPIC_BASE_URL" >&2
		exit 1
	fi
	USE_FAST=1
elif [ "$FORCE_SLOW" -eq 1 ]; then
	USE_FAST=0
elif { [ -n "${ANTHROPIC_API_KEY:-}" ] || [ -n "${ANTHROPIC_BASE_URL:-}" ]; } \
     && [ "$HAS_POSITIONAL" -eq 0 ]; then
	USE_FAST=1
fi

if [ "$USE_FAST" -eq 1 ]; then
	case "$TONE" in
		conversational) PROMPT="$REPO/prompts/text-clean.conversational.md" ;;
		journal)        PROMPT="$REPO/prompts/text-clean.journal.md" ;;
		*)              PROMPT="$REPO/prompts/text-clean.md" ;;
	esac
	if [ "$STDIN_MODE" -eq 1 ]; then
		"$REPO/bin/llm-rewrite" "$PROMPT"
	else
		RESULT=$("$CLIP" read | "$REPO/bin/llm-rewrite" "$PROMPT")
		if [ -n "$OUTFILE" ]; then
			printf '%s' "$RESULT" > "$OUTFILE"
			echo "Cleaned: $OUTFILE"
		else
			printf '%s' "$RESULT" | "$CLIP" write
			echo "Cleaned: clipboard"
		fi
	fi
else
	if [ "$STDIN_MODE" -eq 1 ]; then
		# claude -p cannot read from stdin as input text; route through temp files
		# so the slash command gets a file path and writes output we can capture.
		_TMP_IN=$(mktemp /tmp/text-clean-in.XXXXXX.txt)
		_TMP_OUT=$(mktemp /tmp/text-clean-out.XXXXXX.txt)
		cat > "$_TMP_IN"
		# Wrap claude in `script` to allocate a PTY: when authenticated via claude.ai
		# OAuth (no ANTHROPIC_API_KEY), `claude -p` requires a TTY to load credentials,
		# otherwise it exits immediately with apiKeySource:"none" and empty result.
		# -E never disables PTY echo (keeps the typescript clean and prevents claude
		# from hanging on echoed stdin). Outer `</dev/null` closes the parent stdin.
		# --permission-mode bypassPermissions: /text-clean uses the Write tool to produce
		# $_TMP_OUT, which would otherwise prompt for approval and fail in headless mode.
		script -q -E never -c \
			"claude -p --permission-mode bypassPermissions '/text-clean${PASSTHROUGH[*]:+ ${PASSTHROUGH[*]}} -outfile $_TMP_OUT $_TMP_IN'" \
			/dev/null </dev/null >&2
		_STATUS=$?
		cat "$_TMP_OUT"
		rm -f "$_TMP_IN" "$_TMP_OUT"
		exit $_STATUS
	fi
	exec claude -p "/text-clean${PASSTHROUGH[*]:+ ${PASSTHROUGH[*]}}"
fi
