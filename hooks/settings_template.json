{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "filesystem": {
      "allowWrite": ["//tmp"]
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",

      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(pwd)",
      "Bash(date)",
      "Bash(env)",
      "Bash(printenv *)",

      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git stash list)",

      "Bash(python3 /home/jon/dev/utility-scripts/freeplane/mm2md.py *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo rm *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(shred *)",
      "Bash(pip install --break-system-packages *)",
      "Bash(pip install * --break-system-packages)",
      "Bash(pip install * --break-system-packages *)",
      "Bash(pip3 install --break-system-packages *)",
      "Bash(pip3 install * --break-system-packages)",
      "Bash(pip3 install * --break-system-packages *)",
      "Bash(python* -m pip install --break-system-packages *)",
      "Bash(python* -m pip install * --break-system-packages)",
      "Bash(python* -m pip install * --break-system-packages *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"🔧 Executing: $TOOL_INPUT\" | head -c 100"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"📝 Processing request in: $CLAUDE_PROJECT_DIR\""
          },
          {
            "type": "command",
            "command": "if [ -z \"$tabtitle\" ]; then dir=$(basename \"$PWD\"); printf '\\033]0;%s\\007' \"$dir\" > /dev/tty; else printf '\\033]0;%s\\007' \"$tabtitle\" > /dev/tty; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ File modified - consider running tests'"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/md-lint-post.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "paplay /usr/share/sounds/gnome/default/alerts/swing.ogg 2>&1 || afplay /System/Library/Sounds/Glass.aiff 2>&1 || true"
          },
          {
            "type": "command",
            "command": "if [ -z \"$tabtitle\" ]; then dir=$(basename \"$PWD\"); printf '\\033]0;%s\\007' \"$dir\" > /dev/tty; else printf '\\033]0;%s\\007' \"$tabtitle\" > /dev/tty; fi"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "paplay /usr/share/sounds/gnome/default/alerts/string.ogg 2>&1 || afplay /System/Library/Sounds/Glass.aiff 2>&1 || true"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "notifications": {
    "tool_permission_requests": true,
    "idle_timeout_minutes": 30
  }
}
